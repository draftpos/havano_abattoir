{
 "creation": "2026-04-22 11:00:00.000000",
 "doc_type": "Receiving",
 "doctype": "Print Format",
 "format": "HTML",
 "html": "<div class=\"print-heading\">\n    <h2 style=\"text-align: center; margin-bottom: 30px; color: #1e293b;\">Receiving Receipt</h2>\n    <div style=\"display: flex; justify-content: space-between; margin-bottom: 25px; padding: 15px; background-color: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0;\">\n        <div>\n            <div style=\"margin-bottom: 5px;\"><strong>Sheet No:</strong> {{ doc.sheet_no }}</div>\n            <div><strong>Customer:</strong> {{ doc.customer_name }}</div>\n        </div>\n        <div style=\"text-align: right;\">\n            <div style=\"margin-bottom: 5px;\"><strong>Date:</strong> {{ doc.get_formatted(\"date\") }}</div>\n            <div><strong>Time:</strong> {{ doc.time }}</div>\n        </div>\n    </div>\n</div>\n\n<h3 style=\"font-size: 14px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; color: #475569;\">Receiving Details</h3>\n<table class=\"table table-bordered table-condensed\">\n    <thead>\n        <tr style=\"background-color: #f1f5f9;\">\n            <th>Description</th>\n            <th class=\"text-right\">Loaded Birds</th>\n            <th class=\"text-right\">KGs</th>\n        </tr>\n    </thead>\n    <tbody>\n        {% for item in doc.receiving_items %}\n        <tr>\n            <td>Birds (Crate Info)</td>\n            <td class=\"text-right\">{{ item.live_birds }}</td>\n            <td class=\"text-right\">{{ item.kg }}</td>\n        </tr>\n        {% endfor %}\n    </tbody>\n    <tfoot>\n        <tr style=\"font-weight: bold; background-color: #f1f5f9;\">\n            <td>TOTALS</td>\n            <td class=\"text-right\">{{ doc.total_live_birds }}</td>\n            <td class=\"text-right\">{{ doc.total_kgs }}</td>\n        </tr>\n    </tfoot>\n</table>\n\n{% if doc.dead_birds %}\n<h3 style=\"font-size: 14px; text-transform: uppercase; letter-spacing: 1px; margin-top: 25px; margin-bottom: 10px; color: #475569;\">Dead Birds (DOA / DIP)</h3>\n<table class=\"table table-bordered table-condensed\">\n    <thead>\n        <tr style=\"background-color: #fee2e2;\">\n            <th>Entry Type</th>\n            <th class=\"text-right\">Count</th>\n            <th class=\"text-right\">Weight (KG)</th>\n        </tr>\n    </thead>\n    <tbody>\n        {% for db in doc.dead_birds %}\n        <tr>\n            <td>{{ db.entry_type }}</td>\n            <td class=\"text-right\">{{ db.no_of_birds }}</td>\n            <td class=\"text-right\">{{ db.weight_kgs }}</td>\n        </tr>\n        {% endfor %}\n    </tbody>\n</table>\n{% endif %}\n\n<div style=\"margin-top: 40px; padding: 15px; border: 1px solid #e2e8f0; border-radius: 8px; background-color: #f8fafc;\">\n    <strong>Average Live Weight:</strong> {{ doc.get_formatted(\"average_live_weight\") }} KG\n</div>\n\n<div style=\"margin-top: 30px; font-size: 11px;\">\n    <h4 style=\"font-size: 12px; text-transform: uppercase; margin-bottom: 8px; border-bottom: 1px solid #e2e8f0; padding-bottom: 4px;\">Terms & Conditions</h4>\n    <p style=\"color: #475569;\">1. All birds are received subject to final counting and weighing during processing.<br>\n    2. DOA/DIP counts must be verified by the customer representative before processing begins.<br>\n    3. The signatory confirms the accuracy of the live bird counts and weights recorded above.</p>\n</div>\n\n<div style=\"margin-top: 60px;\">\n    <div style=\"display: flex; justify-content: space-between; gap: 30px;\">\n        <div style=\"flex: 1; text-align: center;\">\n            <div style=\"border-bottom: 1px solid #000; height: 30px;\"></div>\n            <div style=\"margin-top: 8px; font-weight: bold;\">Customer Representative</div>\n            <div style=\"font-size: 11px; color: #64748b;\">{{ doc.customer_rep or \"\" }}</div>\n        </div>\n        <div style=\"flex: 1; text-align: center;\">\n            <div style=\"border-bottom: 1px solid #000; height: 30px;\"></div>\n            <div style=\"margin-top: 8px; font-weight: bold;\">Foreperson</div>\n            <div style=\"font-size: 11px; color: #64748b;\">{{ doc.foreperson or \"\" }}</div>\n        </div>\n        <div style=\"flex: 1; text-align: center;\">\n            <div style=\"border-bottom: 1px solid #000; height: 30px;\"></div>\n            <div style=\"margin-top: 8px; font-weight: bold;\">Security Personnel</div>\n            <div style=\"font-size: 11px; color: #64748b;\">{{ doc.security or \"\" }}</div>\n        </div>\n    </div>\n</div>\n\n<div style=\"margin-top: 50px; font-size: 10px; color: #94a3b8; text-align: center; font-style: italic;\">\n    Generated by Havano Abattoir Management System\n</div>",
 "modified": "2026-04-22 11:00:00.000000",
 "modified_by": "Administrator",
 "module": "Havano Abattoir",
 "name": "Receiving Receipt",
